{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(* .env*)",
      "Bash(* .dev*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.dev.vars)",
      "Read(**/.dev.vars.*)",
      "Read(/secrets/**)",
      "Write(**/*.env*)",
      "Write(./.env)",
      "Write(./.env.*)"
    ]
  }
}
